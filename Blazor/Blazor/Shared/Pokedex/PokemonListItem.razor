@using Blazor.Models.Pokedex;


<div class="grid grid-cols-2 bg-slate-200 shadow-inner hover:bg-slate-100 transition-all">
    <div class="bg-slate-700 rounded p-2">
        <div class="flex flex-wrap justify-center">
            <div class="shadow shadow-inner bg-light rounded-full">
                <img class="" src="@Entity.Sprites.FrontDefault.ToString()" />
            </div>
        </div>
        <h1 class="text-center text-light text-lg capitalize">@Entity.Name</h1>
    </div>
    <div class="p-1 relative">
        <div class="absolute top-1/3 left-0 text-5xl text-slate-400">
            #@Entity.Id
        </div>
        <div class="">
            @foreach (var type in Entity.Types)
            {
                <TypeTag Type="@type.Type" />
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Pokemon Entity { get; set; }
}
